backups/
database/
*.backup
*.backup.*
*.bak
*.bak_*
src/**/*.backup.*

# Ephemeral memory shards (runtime; see docs/memory)
workspace/memory/working/
workspace/memory/daily/
workspace/memory/experience/
workspace/memory/history/
workspace/memory/_archive/
workspace/memory/core/*.json

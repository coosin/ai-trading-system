workspace/memory/core/IDENTITY.md
workspace/memory/core/INSTRUCTIONS.md
workspace/memory/core/MEMORY.md
workspace/memory/core/SOUL.md
workspace/memory/core/TRADING.md
workspace/memory/core/USER.md
workspace/trade_history/

# Local config overrides (never commit)
config/local.yaml
config/local.yml
config/local.json
data/config/local.yaml
data/config/local.yml
data/config/local.json

# Sensitive / machine-specific proxy config (never commit)
config/clash_config.yaml
config/subscription.yaml

# OS
.DS_Store
Thumbs.db

# Frontend
frontend/node_modules/

# Reference subtree (optional local clone; not part of trading runtime)
_reference_openclaw/

# Local agent / IDE session transcripts (never commit)
agents/

# Generated experiments/backtests (never commit)
data/backtest/

# Local probe outputs / tuning run dumps / runtime JSON (never commit)
workspace/probes/
workspace/tuning_runs/
data/runtime/
data/.ssl_merged_ca/

# Process bookkeeping (PID files); keep directory only in git
runtime/*
!runtime/.gitkeep

# Ad-hoc config backups (never commit)
config/config.yaml.bak.*
config/*.bak.*

# Runtime collaboration / MCP logs under logs/
logs/collaboration/

# 全智能量化交易系统 - 环境变量示例
# 复制此文件为 .env 并修改配置

# ======================
# 数据库配置
# ======================

# PostgreSQL
POSTGRES_PASSWORD=changeme123
POSTGRES_USER=trader
POSTGRES_DB=trading_db
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ======================
# 监控配置
# ======================

# Grafana
GRAFANA_PASSWORD=admin123
GRAFANA_PORT=3000

# Prometheus
PROMETHEUS_PORT=9090

# Elasticsearch
ELASTICSEARCH_PASSWORD=

# ======================
# 交易配置
# ======================

# 运行模式
MODE=paper_trading  # paper_trading, live_trading, backtesting

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# 交易所API（实盘交易时需要）
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

COINBASE_API_KEY=
COINBASE_API_SECRET=

# ======================
# 风险配置
# ======================

# 风险限制
MAX_DAILY_LOSS_PERCENT=5.0
MAX_POSITION_SIZE_PERCENT=20.0
MAX_LEVERAGE=3.0

# 交易对
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# ======================
# 网络配置
# ======================

# 时区
TZ=UTC

# 代理设置（如果需要）
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ======================
# 系统配置
# ======================

# 数据源API密钥
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
COINGECKO_API_KEY=

# 社交媒体API
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ======================
# 备份配置
# ======================

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 备份通知（可选）
BACKUP_NOTIFICATION_EMAIL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ======================
# 安全配置
# ======================

# JWT密钥
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# 加密密钥
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# IP白名单（逗号分隔）
ALLOWED_IPS=127.0.0.1,192.168.1.0/24

# ======================
# 性能配置
# ======================

# 缓存配置
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE_MB=100
CACHE_COMPRESSION=true

# 线程池大小
MAX_WORKER_THREADS=4
MAX_IO_THREADS=2

# 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
REDIS_POOL_SIZE=5

# ======================
# 开发配置
# ======================

# 调试模式
DEBUG=false

# 测试数据
USE_MOCK_DATA=false
MOCK_DATA_SIZE=1000

# ======================
# 邮件配置（可选）
# ======================

# SMTP服务器
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@trading-system.com

# ======================
# 第三方服务
# ======================

# Sentry错误跟踪
SENTRY_DSN=

# Datadog监控
DATADOG_API_KEY=

# New Relic监控
NEW_RELIC_LICENSE_KEY=

# ======================
# 自定义配置
# ======================

# 自定义指标阈值
CUSTOM_METRIC_THRESHOLD=0.8

# 交易策略参数
STRATEGY_PARAM_1=0.1
STRATEGY_PARAM_2=0.2
STRATEGY_PARAM_3=0.3

# 注意：
# 1. 生产环境务必修改所有默认密码和密钥
# 2. 敏感信息不要提交到版本控制系统
# 3. 定期轮换API密钥和密码
# 4. 使用环境变量或密钥管理服务存储敏感信息
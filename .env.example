# 复制为 .env 后填写。主业务调参见 config/config.yaml；密钥放本文件或 OPENCLAW__ 环境变量。
# 文档：docs/ENGINEERING.md、docs/OPERATIONS.md

MODE=simulation
TRADING_MODE=simulation
SYSTEM_MODE=simulation
OKX_TESTNET=0
LOG_LEVEL=INFO

# 本仓库 HTTP API 根地址（脚本/巡检优先读取；与 GET /api/v1/modules/surface/registry 的 api_base_env 一致）
# OPENCLAW_API_BASE=http://127.0.0.1:8000
# 兼容旧名：ACCEPTANCE_BASE、BASE_URL（见 src/utils/openclaw_api_client.py）

# OKX（与 config/config.yaml exchanges.okx.*_env 一致；缺一则无法拉余额/持仓）
# OKX_API_KEY=
# OKX_SECRET=
# OKX_PASSPHRASE=

# DataSourceHub 统一快照：单字段等待与整快照预算（默认已放宽，经代理时勿再设 2.8s）
# OPENCLAW_DATA_HUB_FETCH_TIMEOUT_SEC=22
# OPENCLAW_DATA_HUB_SNAPSHOT_TIMEOUT_SEC=55

# OKX REST 稳定性（经宿主机 HTTP 代理易触发 Server disconnected / 超时时可调大）
# OPENCLAW_OKX_TIMEOUT_TOTAL=40
# OPENCLAW_OKX_TIMEOUT_CONNECT=15
# OPENCLAW_OKX_TIMEOUT_SOCK_READ=25
# OPENCLAW_OKX_MAX_RETRIES=5
# 或令 OKX 忽略环境 HTTP(S)_PROXY、在容器内直连公网（与 config proxy.okx.ignore_env_proxy: true 等效）：
# OPENCLAW_OKX_IGNORE_ENV_PROXY=1
# 禁止直连自愈、强制全程走代理时：
# OPENCLAW_OKX_PROXY_ONLY=1

# Binance / CoinGecko（data_integration 辅助行情）：TLS 已修正；仍断开可调超时与重试
# OPENCLAW_DATASOURCE_HTTP_TIMEOUT=28
# OPENCLAW_DATASOURCE_MAX_RETRIES=4
# OPENCLAW_DATASOURCE_DNS_TTL=300

# LLM：代理频繁 RemoteProtocolError / 读超时时，允许对该 Provider 切换为直连（须能访问各模型 base_url）
# OPENCLAW_LLM_DIRECT_FALLBACK=1

# LLM（示例）
# OPENAI_API_KEY=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 裸机：代理写本机 mixed-port（与 mihomo / Clash 一致）。勿使用 host.docker.internal（仅历史上容器访问宿主机用）。
#
# 与「当前」宿主机代理试配：在 .env 写明实际地址（换代理后改这里即可）
# 推荐仅 HTTP mixed-port；SOCKS5 不稳定时不要设 ALL_PROXY / OPENCLAW_ALL_PROXY（会拖慢或失败）
# OPENCLAW_HTTP_PROXY=http://127.0.0.1:7890
# OPENCLAW_HTTPS_PROXY=http://127.0.0.1:7890
# production_network_baseline.py：默认在本机 Python 探针（裸金属生产）
# mixed-port 若只监听 127.0.0.1：本机进程用 http://127.0.0.1:端口 即可；若需局域网其它机器连入站，让 mixed-port 监听 0.0.0.0
# OPENCLAW_HOST_HTTP_PROXY=http://127.0.0.1:7890
# CLASH_MIXED_PORT=7890

# --- LLM / traces / third-party (optional) ---
# OPENCLAW_LLM_REQUEST_TIMEOUT_SEC=90
# OPENCLAW_DECISION_TRACE_PERSIST=1
# OPENCLAW_THIRD_PARTY_MIN_INTERVAL_SEC=2.0
# LLM 熔断冷却（秒）：失败类型见 enhanced_llm_manager._apply_failure_circuit_break（RATE_LIMIT / QUOTA / TIMEOUT / NETWORK）
# OPENCLAW_LLM_CB_RATE_LIMIT_SEC=180
# OPENCLAW_LLM_CB_QUOTA_SEC=21600
# OPENCLAW_LLM_CB_TIMEOUT_SEC=45
# OPENCLAW_LLM_CB_NETWORK_SEC=30
# OKX TLS: extra CA PEM merged with certifi (HTTPS proxy MITM)
# OPENCLAW_SSL_CA_BUNDLE=/path/to/extra-root-ca.pem
# OPENCLAW_OKX_INSECURE_SSL=1
# Prefer system CA bundle on Debian/Ubuntu (often fresher than bundled certifi alone):
# SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

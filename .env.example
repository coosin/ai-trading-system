# OpenClaw Trading - 环境变量配置模板
# 复制此文件为 .env 并修改配置
# 重要: 生产环境务必修改所有默认密码和密钥!

# ======================
# AI模型配置
# ======================

# 讯飞AI (主要模型)
XUNFEI_API_KEY=your_xunfei_api_key_here

# OpenAI (可选)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (可选)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (可选)
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek (可选)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 (可选)
QWEN_API_KEY=your_qwen_api_key_here

# ======================
# 交易所配置
# ======================

# OKX交易所 (主要交易所)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET=your_okx_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# Binance交易所 (可选)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# ======================
# 通知配置
# ======================

# Telegram机器人
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 邮件通知 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here
SMTP_FROM=noreply@openclaw-trading.com

# ======================
# 数据库配置
# ======================

# PostgreSQL (可选,默认使用SQLite)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=trading_db

# Redis (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================
# 监控配置
# ======================

# Grafana
GRAFANA_PASSWORD=admin123
GRAFANA_PORT=3000

# Prometheus
PROMETHEUS_PORT=9090

# ======================
# 风险配置
# ======================

# 风险限制
MAX_DAILY_LOSS_PERCENT=5.0
MAX_POSITION_SIZE_PERCENT=20.0
MAX_LEVERAGE=3.0

# 交易对
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT

# ======================
# 网络配置
# ======================

# 时区
TZ=Asia/Shanghai

# 代理设置 (Clash代理)
# Clash默认端口: HTTP=7890, SOCKS5=7891
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
ALL_PROXY=socks5://127.0.0.1:7891
NO_PROXY=localhost,127.0.0.1,*.local,*.internal

# 代理认证 (如果需要)
PROXY_USER=
PROXY_PASSWORD=

# Clash配置路径 (可选，用于自动检测)
CLASH_CONFIG_PATH=~/.config/clash/config.yaml

# ======================
# 系统配置
# ======================

# 运行模式
MODE=simulation  # simulation, paper_trading, live_trading, backtesting

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_api_key_here  # API访问密钥

# ======================
# 数据源API密钥
# ======================

# CoinGecko
COINGECKO_API_KEY=

# Glassnode
GLASSNODE_API_KEY=

# CryptoQuant
CRYPTOQUANT_API_KEY=

# ======================
# 社交媒体API (可选)
# ======================

# Twitter
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Telegram (用于数据采集)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ======================
# 第三方服务 (可选)
# ======================

# LunarCrush (社交媒体分析)
LUNARCRUSH_API_KEY=

# Santiment (链上数据分析)
SANTIMENT_API_KEY=

# Alternative.me (恐惧贪婪指数)
ALTERNATIVE_ME_API_KEY=

# News API
NEWS_API_KEY=
NEWS_API_SECRET=

# Sentry错误跟踪
SENTRY_DSN=

# Datadog监控
DATADOG_API_KEY=

# New Relic监控
NEW_RELIC_LICENSE_KEY=

# ======================
# 备份配置
# ======================

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# ======================
# 安全配置
# ======================

# JWT密钥 (用于API认证)
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# 加密密钥 (用于敏感数据加密)
ENCRYPTION_KEY=your_encryption_key_here_change_in_production

# ======================
# 性能配置
# ======================

# 线程池
MAX_WORKER_THREADS=4
MAX_IO_THREADS=2

# 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
REDIS_POOL_SIZE=5

# ======================
# 开发配置
# ======================

# 调试模式
DEBUG=false

# 测试数据
USE_MOCK_DATA=false
MOCK_DATA_SIZE=1000

# ======================
# 注意事项
# ======================

# 1. 生产环境务必修改所有默认密码和密钥
# 2. 敏感信息不要提交到版本控制系统
# 3. 定期轮换API密钥和密码
# 4. 使用环境变量或密钥管理服务存储敏感信息
# 5. 确保.env文件在.gitignore中
